{
  "name": "mitable",
  "version": "0.1.0",
  "private": true,
  "description": "Mitable AI Onboarding Buddy - Intelligent desktop assistant for contextual employee onboarding",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:debug-screenshots": "DEBUG_SAVE_SCREENSHOTS=true turbo run dev",
    "dev:backend": "npm run dev --workspace=apps/backend",
    "dev:admin": "concurrently \"npm run dev --workspace=apps/backend\" \"npm run dev:admin --workspace=apps/electron\"",
    "dev:employee": "concurrently \"npm run dev --workspace=apps/backend\" \"npm run dev:employee --workspace=apps/electron\"",
    "dev:admin:windows": "concurrently \"npm run dev --workspace=apps/backend\" \"npm run dev:admin:windows --workspace=apps/electron\"",
    "dev:employee:windows": "concurrently \"npm run dev --workspace=apps/backend\" \"npm run dev:employee:windows --workspace=apps/electron\"",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "ci": "npm run build --workspace=packages/shared && npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "shadcn": "^3.4.0",
    "ts-jest": "^29.4.5",
    "turbo": "^1.12.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@slack/web-api": "^7.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7"
  }
}
