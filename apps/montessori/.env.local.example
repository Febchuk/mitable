# Mitable for Montessori — local dev configuration
#
# Copy this file to apps/montessori/.env.local and fill in the values
# from your dev Supabase project (the same one apps/backend uses).

# Supabase — public client config (exposed to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Mitable backend (Express) base URL. Defaults to the page origin if
# omitted, so this is only required when the Next.js dev server runs on
# a different host/port than the backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
