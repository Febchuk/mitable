  "scripts": {
    "dev": "cross-env VITE_USER_ROLE=employee electron-vite dev --mode development",
    "dev:prod": "cross-env VITE_USER_ROLE=employee electron-vite dev --mode production",
    "dev:admin": "cross-env VITE_USER_ROLE=admin electron-vite dev --mode development",
    "dev:admin:prod": "cross-env VITE_USER_ROLE=admin electron-vite dev --mode production",
