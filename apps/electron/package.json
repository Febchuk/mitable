    "dev:employee:windows": "cross-env VITE_USER_ROLE=employee electron-vite dev --mode development",
    "build": "electron-vite build",
    "build:mac": "npm run build && electron-builder --mac --publish never",
    "build:mac:arm64": "npm run build && electron-builder --mac --arm64 --publish never",
    "build:mac:x64": "npm run build && electron-builder --mac --x64 --publish never",
    "build:win": "npm run build && electron-builder --win --publish never",
    "build:linux": "npm run build && electron-builder --linux --publish never",
    "preview": "electron-vite preview",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf out dist",
    "logs": "tail -f ~/Library/Logs/mitable/main.log",
    "logs:clear": "rm -f ~/Library/Logs/mitable/*.log && echo 'Logs cleared'"
