# Mitable Environment Configuration Example
# Copy this file to .env and fill in your values

# =============================================================================
# Capture Policy Configuration
# =============================================================================
# Control which applications/URLs Mitable is allowed to capture screenshots from
# Uses comma-separated list of case-insensitive patterns (supports regex)
# If not set, defaults to blocking common PII-heavy apps

# Apps/Windows to DENY capture (never screenshot these)
# Examples: outlook,gmail,mail,1password,slack,teams
CAPTURE_DENY_APPS=outlook,gmail,mail,messages,1password,lastpass,bitwarden,okta,slack

# URLs to DENY capture (for browser windows)
# Examples: mail.google.com,drive.google.com,bankofamerica.com
CAPTURE_DENY_URLS=mail.google.com,drive.google.com,bankofamerica,chase,wellsfargo

# =============================================================================
# Notes:
# =============================================================================
# - Patterns are case-insensitive
# - Partial matches work (e.g., "mail" blocks "Gmail", "Outlook Mail", etc.)
# - OS-agnostic: "slack" blocks "Slack.exe" (Windows), "Slack.app" (Mac), "slack" (Linux)
# - Full-screen capture is disabled - only app-specific captures allowed
# - If ENV is set, it overrides default deny list entirely
# - Leave empty to use built-in defaults
