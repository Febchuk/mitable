# ==============================================================================
# Mitable Electron App Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values.
# These variables are used by both the main process and the renderer (via Vite).
# Variables prefixed with VITE_ are exposed to the renderer process.
# ==============================================================================

# ------------------------------------------------------------------------------
# API Connection
# ------------------------------------------------------------------------------

# [Optional] Backend API URL (default: http://localhost:3000)
# In production, this points to the deployed backend.
VITE_API_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# User Role (Console Window Mode)
# ------------------------------------------------------------------------------

# [Optional] Console window mode: "employee" or "admin" (default: employee)
# Typically set via npm scripts (npm run dev vs npm run dev:admin), not in .env.
VITE_USER_ROLE=employee

# ------------------------------------------------------------------------------
# Dev Server
# ------------------------------------------------------------------------------

# [Optional] Vite dev server port (default: 5173)
# Use different ports for multi-instance development.
VITE_PORT=5173

# ------------------------------------------------------------------------------
# Supabase (Renderer Auth)
# ------------------------------------------------------------------------------

# [Optional] Supabase project URL (renderer-side auth)
VITE_SUPABASE_URL=https://your-project.supabase.co

# [Optional] Supabase anon key (renderer-side auth)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ------------------------------------------------------------------------------
# Analytics - PostHog
# ------------------------------------------------------------------------------

# [Optional] PostHog project API key (main process)
POSTHOG_API_KEY=your-posthog-api-key

# [Optional] PostHog host (main process, default: https://us.i.posthog.com)
POSTHOG_HOST=https://us.i.posthog.com

# [Optional] PostHog project API key (renderer process)
VITE_POSTHOG_KEY=your-posthog-api-key

# [Optional] PostHog host (renderer process, default: https://us.i.posthog.com)
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ------------------------------------------------------------------------------
# Integrations
# ------------------------------------------------------------------------------

# [Optional] Linear app name for OAuth display (default: Mitable-dev)
VITE_LINEAR_APP_NAME=Mitable-dev

# ------------------------------------------------------------------------------
# Capture Policy
# ------------------------------------------------------------------------------

# [Optional] Comma-separated list of app names to exclude from screen capture
CAPTURE_DENY_APPS=

# ------------------------------------------------------------------------------
# Auto-Update
# ------------------------------------------------------------------------------

# [Optional] GitHub token for private repo auto-update checks
GH_TOKEN=
