{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node", "electron", "jest", "@testing-library/jest-dom"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/renderer/*"]
    }
  },
  "include": [
    "src/main.ts",
    "src/preload/**/*",
    "src/renderer/**/*",
    "src/global.d.ts",
    "src/renderer/agent/src/global.d.ts",
    "src/renderer/console/src/global.d.ts",
    "src/renderer/watchButton/src/global.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
