# Apple Developer Signing Credentials
# Copy this file to .env.signing and fill in your values
# NEVER commit .env.signing to version control!

# Your Apple ID email
export APPLE_ID=your@email.com

# App-specific password (generate at https://appleid.apple.com)
# Security > App-Specific Passwords > Generate
export APPLE_ID_PASSWORD=xxxx-xxxx-xxxx-xxxx
export APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Your Apple Team ID (found in Developer Portal or from your certificate)
# Run: security find-identity -v -p codesigning
export APPLE_TEAM_ID=XXXXXXXXXX
