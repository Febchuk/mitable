# Production Environment Configuration
# Copy this file to .env.production and fill in actual values

# API Base URL (Railway Production)
VITE_API_URL=https://mitablebackend-production.up.railway.app

# Database
DATABASE_URL=your_production_database_url_here
DIRECT_URL=your_production_direct_url_here

# Supabase
SUPABASE_URL=your_production_supabase_url
SUPABASE_ANON_KEY=your_production_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key

# API Keys
OPENAI_API_KEY=your_openai_api_key
GROQ_API_KEY=your_groq_api_key
PINECONE_API_KEY=your_pinecone_api_key
GEMINI_API_KEY=your_gemini_api_key

# OAuth
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_REDIRECT_URI=https://mitablebackend-production.up.railway.app/api/integrations/slack/callback

NOTION_CLIENT_ID=your_notion_client_id
NOTION_CLIENT_SECRET=your_notion_client_secret
NOTION_REDIRECT_URI=https://mitablebackend-production.up.railway.app/api/integrations/notion/callback

# Security
JWT_SECRET=your_jwt_secret_here
ALLOWED_ORIGINS=http://localhost:5173

# Railway Public API (optional — in-app feedback: fetch user-scoped backend logs)
# Use an account/workspace token (Bearer) OR a project token (Project-Access-Token header).
# Railway UI often says to use RAILWAY_TOKEN — that works here (or RAILWAY_API_TOKEN).
# RAILWAY_TOKEN=
# RAILWAY_API_TOKEN=
# RAILWAY_PROJECT_ACCESS_TOKEN=
# RAILWAY_ENVIRONMENT_ID=
# RAILWAY_BACKEND_SERVICE_ID=

# Google Cloud (Optional - for PII redaction)
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_KEY_PATH=
