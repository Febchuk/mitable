{
  "name": "@mitable/backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:migrate-fts": "tsx src/scripts/run-fts-migration.ts",
    "clear-search-data": "tsx src/scripts/clear-search-data.ts",
    "verify-dual-write": "tsx src/scripts/verify-dual-write.ts",
    "test-search": "tsx src/scripts/test-search.ts",
    "sync-slack": "tsx src/scripts/sync-slack.ts"
  },
  "dependencies": {
    "@google-cloud/dlp": "^6.5.0",
    "@google/generative-ai": "^0.24.1",
    "@mitable/shared": "*",
    "@notionhq/client": "^5.2.1",
    "@pinecone-database/pinecone": "^6.1.2",
    "@slack/web-api": "^7.11.0",
    "@supabase/supabase-js": "^2.75.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.44.6",
    "drizzle-zod": "^0.8.3",
    "express": "^4.18.3",
    "node-cache": "^5.1.2",
    "openai": "^6.3.0",
    "pg": "^8.13.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tiktoken": "^1.0.22",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.30",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.31.5",
    "drizzle-seed": "^0.3.1",
    "supertest": "^7.1.4",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
