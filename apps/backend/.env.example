# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/database?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:port/database

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI Configuration (for embeddings)
OPENAI_API_KEY=sk-your-openai-api-key

# Groq Configuration (for chat completions)
GROQ_API_KEY=your-groq-api-key

# Pinecone Configuration
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=mitable-embeddings

# Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key

# Slack OAuth Configuration
# Get these from https://api.slack.com/apps -> Your App -> OAuth & Permissions
SLACK_CLIENT_ID=slack-client-id
SLACK_CLIENT_SECRET=slack-client-secret
SLACK_REDIRECT_URI=http://localhost:3000/api/integrations/slack/callback

# Notion OAuth Configuration
NOTION_CLIENT_ID=your-client-id
NOTION_CLIENT_SECRET=your-client-secret
NOTION_REDIRECT_URI=http://localhost:3000/api/integrations/notion/callback

# Gmail OAuth Configuration (per-user email sending)
# Get from Google Cloud Console -> APIs & Services -> Credentials
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REDIRECT_URI=http://localhost:3000/api/integrations/gmail/callback

# Google Cloud DLP Configuration (for PII Redaction)
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_KEY_PATH=./creds/your-service-account-key.json

# Security
JWT_SECRET=your-secure-jwt-secret-at-least-32-characters-long

# Token Encryption (CRITICAL)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be 64 hex characters (32 bytes for AES-256)
# KEEP SECRET - If leaked, regenerate immediately and re-encrypt all tokens
ENCRYPTION_KEY=generate-with-command-above-64-hex-chars

# =============================================================================
# OBSERVABILITY (Logging, Error Tracking, Analytics)
# =============================================================================

# Sentry Configuration (Error Tracking)
# Get DSN from https://sentry.io -> Project Settings -> Client Keys (DSN)
SENTRY_DSN=

# PostHog Configuration (Product Analytics)
# Get API key from https://app.posthog.com -> Project Settings -> Project API Key
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

