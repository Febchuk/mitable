# ==============================================================================
# Mitable Backend Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values.
# Variables marked [Required] must be set for the server to start in production.
# Variables marked [Optional] have sensible defaults or enable optional features.
# ==============================================================================

# ------------------------------------------------------------------------------
# App
# ------------------------------------------------------------------------------

# [Optional] Node environment (development | production | test)
NODE_ENV=development

# [Optional] Server port (default: 3000). Can also be set via CLI --port flag.
PORT=3000

# [Optional] Backend public URL, used for password-reset redirects and OAuth callbacks
BACKEND_URL=http://localhost:3000

# [Optional] Comma-separated CORS origins (default: http://localhost:5173,http://localhost:3003)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3003

# ------------------------------------------------------------------------------
# Database (Supabase PostgreSQL)
# ------------------------------------------------------------------------------

# [Required] Pooled connection string (used by the application)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:6543/postgres

# [Optional] Direct connection string (used for migrations; falls back to DATABASE_URL)
DIRECT_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ------------------------------------------------------------------------------
# Supabase
# ------------------------------------------------------------------------------

# [Required] Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# [Required] Supabase anon (public) key
SUPABASE_ANON_KEY=your-supabase-anon-key

# [Optional] Supabase service role key (server-side admin access)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------------------------
# Auth / Security
# ------------------------------------------------------------------------------

# [Required] Secret used to sign and verify JWT tokens
JWT_SECRET=your-jwt-secret-at-least-32-chars

# ------------------------------------------------------------------------------
# AI - Google Gemini (Vision + Chat)
# ------------------------------------------------------------------------------

# [Required] Google Gemini API key (screenshot analysis, vision tasks)
GEMINI_API_KEY=your-gemini-api-key

# ------------------------------------------------------------------------------
# AI - OpenAI (Embeddings)
# ------------------------------------------------------------------------------

# [Required] OpenAI API key (used for text-embedding-3-small, 1536 dimensions)
OPENAI_API_KEY=your-openai-api-key

# [Optional] OpenAI chat model (default: gpt-4-turbo-preview)
OPENAI_CHAT_MODEL=gpt-4-turbo-preview

# [Optional] Max tokens for OpenAI chat (default: 2000)
OPENAI_MAX_TOKENS=2000

# [Optional] Temperature for OpenAI chat (default: 0.7)
OPENAI_TEMPERATURE=0.7

# ------------------------------------------------------------------------------
# AI - Groq (Chat Completions)
# ------------------------------------------------------------------------------

# [Required] Groq API key
GROQ_API_KEY=your-groq-api-key

# [Optional] Groq chat model (default: openai/gpt-oss-120b)
GROQ_CHAT_MODEL=openai/gpt-oss-120b

# [Optional] Max tokens for Groq chat (default: 8000)
GROQ_MAX_TOKENS=8000

# [Optional] Temperature for Groq chat (default: 0.7)
GROQ_TEMPERATURE=0.7

# ------------------------------------------------------------------------------
# AI - Anthropic (Storyteller summarization - Claude Sonnet 4.5 with extended thinking)
# ------------------------------------------------------------------------------

# [Optional] Anthropic API key (fallback narrative provider)
ANTHROPIC_API_KEY=your-anthropic-api-key

# ------------------------------------------------------------------------------
# AI - DeepSeek (Fallback for narrative services - DeepSeek V3.2)
# ------------------------------------------------------------------------------

# [Optional] DeepSeek API key (fallback narrative provider)
DEEPSEEK_API_KEY=your-deepseek-api-key

# ------------------------------------------------------------------------------
# AI - Deepgram (Audio Transcription)
# ------------------------------------------------------------------------------

# [Optional] Deepgram API key for audio transcription
DEEPGRAM_API_KEY=your-deepgram-api-key

# ------------------------------------------------------------------------------
# Vector Store (Pinecone)
# ------------------------------------------------------------------------------

# [Required] Pinecone API key
PINECONE_API_KEY=your-pinecone-api-key

# [Required] Pinecone index name (must be configured for 1536 dimensions)
PINECONE_INDEX_NAME=mitable-embeddings

# ------------------------------------------------------------------------------
# Integration - Slack OAuth
# ------------------------------------------------------------------------------

# [Required] Slack app client ID
SLACK_CLIENT_ID=your-slack-client-id

# [Required] Slack app client secret
SLACK_CLIENT_SECRET=your-slack-client-secret

# [Optional] Slack OAuth redirect URI (default: http://localhost:{PORT}/api/integrations/slack/callback)
SLACK_REDIRECT_URI=

# ------------------------------------------------------------------------------
# Integration - Notion OAuth
# ------------------------------------------------------------------------------

# [Required] Notion integration client ID
NOTION_CLIENT_ID=your-notion-client-id

# [Required] Notion integration client secret
NOTION_CLIENT_SECRET=your-notion-client-secret

# [Optional] Notion OAuth redirect URI (default: http://localhost:{PORT}/api/integrations/notion/callback)
NOTION_REDIRECT_URI=

# [Optional] Notion user-level redirect URI (default: http://localhost:{PORT}/api/integrations/notion/user/callback)
NOTION_USER_REDIRECT_URI=

# ------------------------------------------------------------------------------
# Integration - GitHub App
# ------------------------------------------------------------------------------

# [Optional] GitHub App ID (numeric)
GITHUB_APP_ID=0

# [Optional] GitHub App OAuth client ID
GITHUB_APP_CLIENT_ID=your-github-app-client-id

# [Optional] GitHub App OAuth client secret
GITHUB_APP_CLIENT_SECRET=your-github-app-client-secret

# [Optional] GitHub App slug (URL-friendly name)
GITHUB_APP_SLUG=your-github-app-slug

# [Optional] GitHub App private key (PEM format, used for JWT signing)
GITHUB_APP_PRIVATE_KEY=

# [Optional] GitHub App installation redirect URI
GITHUB_APP_REDIRECT_URI=

# ------------------------------------------------------------------------------
# Integration - Linear OAuth
# ------------------------------------------------------------------------------

# [Optional] Linear OAuth client ID
LINEAR_CLIENT_ID=your-linear-client-id

# [Optional] Linear OAuth client secret
LINEAR_CLIENT_SECRET=your-linear-client-secret

# [Optional] Linear OAuth redirect URI (default: http://localhost:{PORT}/api/integrations/linear/callback)
LINEAR_REDIRECT_URI=

# ------------------------------------------------------------------------------
# Integration - Gmail OAuth
# ------------------------------------------------------------------------------

# [Optional] Gmail OAuth client ID (Google Cloud Console)
GMAIL_CLIENT_ID=your-gmail-client-id

# [Optional] Gmail OAuth client secret
GMAIL_CLIENT_SECRET=your-gmail-client-secret

# [Optional] Gmail OAuth redirect URI (default: http://localhost:{PORT}/api/integrations/gmail/callback)
GMAIL_REDIRECT_URI=

# ------------------------------------------------------------------------------
# Integration - Granola (MCP OAuth - no client credentials needed)
# ------------------------------------------------------------------------------

# [Optional] Granola OAuth redirect URI (default: http://localhost:{PORT}/api/integrations/granola/callback)
GRANOLA_REDIRECT_URI=

# [Optional] Granola MCP base URL (default: https://mcp.granola.ai)
GRANOLA_MCP_BASE_URL=https://mcp.granola.ai

# ------------------------------------------------------------------------------
# Integration - Fireflies AI (per-user API key, no server-level key needed)
# ------------------------------------------------------------------------------

# [Optional] Fireflies GraphQL API URL (default: https://api.fireflies.ai/graphql)
FIREFLIES_API_URL=https://api.fireflies.ai/graphql

# ------------------------------------------------------------------------------
# Billing (Stripe)
# ------------------------------------------------------------------------------

# [Optional] Stripe secret key (required for billing features)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# [Optional] Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# [Optional] Stripe Pro plan price ID
STRIPE_PRO_PRICE_ID=price_your-pro-price-id

# [Optional] Stripe Team plan price ID
STRIPE_TEAM_PRICE_ID=price_your-team-price-id

# ------------------------------------------------------------------------------
# Graph Intelligence (Neo4j - staged rollout, disabled by default)
# ------------------------------------------------------------------------------

# [Optional] Enable graph features (default: false)
GRAPH_ENABLED=false

# [Required when GRAPH_ENABLED=true] Neo4j connection URI
GRAPH_URI=bolt://localhost:7687

# [Required when GRAPH_ENABLED=true] Neo4j username
GRAPH_USER=neo4j

# [Required when GRAPH_ENABLED=true] Neo4j password
GRAPH_PASSWORD=your-neo4j-password

# [Optional] Neo4j database name (default: neo4j)
GRAPH_DATABASE=neo4j

# [Optional] Number of top facts to retrieve from graph (default: 5)
GRAPH_TOP_K_FACTS=5

# [Optional] Lookback window in days for graph queries (default: 30)
GRAPH_LOOKBACK_DAYS=30

# ------------------------------------------------------------------------------
# Google Cloud DLP (PII Redaction)
# ------------------------------------------------------------------------------

# [Optional] Google Cloud project ID for DLP
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# [Optional] Path to Google Cloud service account key file
GOOGLE_CLOUD_KEY_PATH=

# ------------------------------------------------------------------------------
# Email (Resend)
# ------------------------------------------------------------------------------

# [Optional] Resend API key for transactional emails
RESEND_API_KEY=your-resend-api-key

# [Optional] From address for outgoing emails (default: Mitable AI <noreply@mitable.ai>)
RESEND_FROM_ADDRESS=Mitable AI <noreply@mitable.ai>

# ------------------------------------------------------------------------------
# Feedback
# ------------------------------------------------------------------------------

# [Optional] Primary recipient for in-app feedback emails
FEEDBACK_EMAIL_TO=your-email@example.com

# [Optional] Comma-separated CC list for feedback emails
FEEDBACK_EMAIL_CC=

# ------------------------------------------------------------------------------
# Railway (Log retrieval for feedback reports)
# ------------------------------------------------------------------------------

# [Optional] Railway account or workspace API token
RAILWAY_API_TOKEN=

# [Optional] Railway project-scoped access token (alternative to RAILWAY_API_TOKEN)
RAILWAY_PROJECT_ACCESS_TOKEN=

# [Optional] Railway environment ID
RAILWAY_ENVIRONMENT_ID=

# [Optional] Railway backend service ID
RAILWAY_BACKEND_SERVICE_ID=

# ------------------------------------------------------------------------------
# Monitoring - PostHog (Product Analytics)
# ------------------------------------------------------------------------------

# [Optional] PostHog API key for server-side analytics
POSTHOG_API_KEY=your-posthog-api-key

# [Optional] PostHog host (default: https://app.posthog.com)
POSTHOG_HOST=https://app.posthog.com

# ------------------------------------------------------------------------------
# Monitoring - Sentry (Error Tracking)
# ------------------------------------------------------------------------------

# [Optional] Sentry DSN for error reporting
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
