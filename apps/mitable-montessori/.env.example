NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
NEXT_PUBLIC_APP_NAME=mitable-montessori

# Speech + OCR capture worker (Whisper / Tesseract in capture.worker.ts). Required for voice notes on new reports.
NEXT_PUBLIC_ENABLE_CAPTURE_WORKER=1

# Teacher-invite emails (Resend). Without this, /api/admin/teachers/invite will reject sends.
RESEND_API_KEY=
# From address. Defaults to onboarding@resend.dev (only delivers to your Resend account email).
# Once you verify a domain in Resend, set: RESEND_FROM="Mitable <noreply@yourdomain.com>"
RESEND_FROM=

# Public origin used to build invite links in outbound emails. Falls back to the request Origin if unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000
